rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 유저 프로필: 본인만 읽기/쓰기, 리더보드 목적으로 모두 읽기 허용
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // 베팅: 본인 베팅만 읽기/생성 가능 (수정 불가)
    match /bets/{betId} {
      allow read: if request.auth != null &&
        (resource.data.uid == request.auth.uid || true); // 리더보드용 집계 허용
      allow create: if request.auth != null &&
        request.resource.data.uid == request.auth.uid;
      allow update, delete: if false; // 서버(Admin SDK)만 가능
    }

    // 일별 결과: 누구나 읽기, 쓰기는 서버만
    match /daily/{date} {
      allow read: if true;
      allow write: if false; // Admin SDK만
    }
  }
}
